rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Match photos — public read, size-limited write (20 MB cap)
    // contentType check removed: the SDK does not reliably surface it in rules
    // when uploading a File/Blob, causing false storage/unauthorized errors.
    match /match-photos/{file} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024;
    }
    // Dev-mode match photos (prefixed by DEV_ROOT = '_dev/')
    match /_dev/match-photos/{file} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024;
    }
    // All other paths are denied by default
  }
}
